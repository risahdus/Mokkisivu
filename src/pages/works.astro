---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Työlista & Projektit">
    
    <div class="projektit-otsikko">
        <h2><i class="fa-solid fa-tools"></i> Työlista & Projektit</h2>
        <p>Hallitse mökin remontteja ja tarvikelistoja.</p>
    </div>

    <div class="kortti-ruudukko">
        
        <a href="/projekti/uusi" class="laatikko laatikko-kuvalla" style="background-image: url('/newproject.jpg');">
            <div class="kortti-sisalto keskitys">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-circle-plus" style="color: #3b82f6;"></i> 
                    <h2>Lisää uusi projekti</h2>
                </div>
            </div>
        </a>

        <a href="/projekti/avoimet" class="laatikko laatikko-kuvalla" style="background-image: url('/openprojects.jpg');">
            <div class="kortti-sisalto keskitys">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-hourglass-half" style="color: #f59e0b;"></i> 
                    <h2>Avoimet projektit</h2>
                </div>
            </div>
        </a>

        <a href="/projekti/valmiit" class="laatikko laatikko-kuvalla" style="background-image: url('/readyprojects.jpg');">
            <div class="kortti-sisalto keskitys">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-circle-check" style="color: #10b981;"></i> 
                    <h2>Valmiit projektit</h2>
                </div>
            </div>
        </a>

    </div>

    <div style="margin-top: 20px;">
        <a href="#" onclick="history.back(); return false;" class="paluu-linkki">
            <i class="fa-solid fa-arrow-left"></i> Takaisin etusivulle
        </a>
    </div>

</MainLayout>

<style>
    .projektit-otsikko {
        margin-bottom: 32px;
        text-align: center;
    }
    .projektit-otsikko h2 {
        font-size: 2.2rem;
        color: #1a1a1a;
        margin-bottom: 8px;
    }
    
    /* Ruudukko korteille */
    .kortti-ruudukko {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 32px;
    }

    /* Käytetään etusivulta tuttua laatikko-kuvalla tyyliä */
    .laatikko-kuvalla {
        height: 180px;
        position: relative;
        background-size: cover;
        background-position: center;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .laatikko-kuvalla:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }

    .kortti-sisalto {
        background: rgba(255, 255, 255, 0.9); /* Vaalea tausta tekstille, jotta erottuu kuvan päältä */
        width: 100%;
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease;
    }

    .laatikko-kuvalla:hover .kortti-sisalto {
        background: rgba(255, 255, 255, 0.95);
    }

    .otsikko-rivi {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .otsikko-rivi i {
        font-size: 1.8rem;
    }

    .otsikko-rivi h2 {
        font-size: 1.4rem;
        color: #1a1a1a;
        margin: 0;
        font-weight: 700;
    }

    .paluu-linkki {
        display: inline-block;
        color: #333;
        text-decoration: none;
        font-weight: 600;
        padding: 8px 16px;
        background: #f0f0f0;
        border-radius: 6px;
        transition: background 0.2s;
    }
    .paluu-linkki:hover {
        background: #e0e0e0;
    }
</style>