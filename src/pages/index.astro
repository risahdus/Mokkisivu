---
// Tuodaan yhteinen sivupohja uudella englanninkielisellä nimellä
import MainLayout from '../layouts/MainLayout.astro';

// BACKEND: Muuttujat englanniksi
let isAuthenticated = false;
let errorMessage = "";
const CORRECT_PASSWORD = "Mokki2026";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const enteredPassword = data.get("password");

    if (enteredPassword === CORRECT_PASSWORD) {
      isAuthenticated = true;
    } else {
      errorMessage = "Wrong password, try again!";
    }
  } catch (error) {
    console.error(error);
  }
}
---

<MainLayout title="Cottage Project - Home">
    
    { !isAuthenticated ? (
        <!-- VIEW A: Login Form -->
        <div class="laatikko kirjautuminen">
            <h2>Page is protected</h2>
            <p>Enter the password to see the renovation list.</p>
            
            <form method="POST">
                <input type="password" name="password" placeholder="Password" required />
                { errorMessage && <p class="virhe">{errorMessage}</p> }
                <button type="submit">Log In</button>
            </form>
        </div>
    ) : (
        <!-- VIEW B: Dynamic Content -->
        <div class="laatikko">
            <h2>To-Do List & Supplies</h2>
            <ul>
                <li>
                    <span>Terassin laajennus</span>
                    <span class="status kesken">Tarvikkeet ostamatta</span>
                </li>
                <li>
                    <span>Saunan lauteiden vahaus</span>
                    <span class="status tehty">Tehty & hankittu</span>
                </li>
            </ul>
        </div>

        <div class="laatikko">
            <h2>Guestbook</h2>
            <p>Tähän tulee myöhemmin lomake, johon voi kirjoittaa viestejä.</p>
        </div>
    ) }

</MainLayout>