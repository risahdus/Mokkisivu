---
import MainLayout from '../layouts/MainLayout.astro';
import { supabase } from '../lib/supabase';

// BACKEND: Kirjautumisen käsittely Supabasella
let isAuthenticated = false;
let errorMessage = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const email = data.get("email");
    const password = data.get("password");

    // Pyydetään Supabasea tarkistamaan tunnus ja salasana
    const { data: authData, error } = await supabase.auth.signInWithPassword({
      email: email,
      password: password,
    });

    if (error) {
      console.error("Supabase Auth virhe:", error.message); // TÄMÄ RIVI TULOSTAA TARKAN SYYN LOKIIN
      errorMessage = "Väärä tunnus tai salasana! (Syy: " + error.message + ")"; // Näytetään syy myös ruudulla
    } else if (authData.user) {
      isAuthenticated = true;
    }  
  } catch (error) {
    console.error(error);
    errorMessage = "Yhteysvirhe, yritä uudelleen.";
  }
}
---

<MainLayout title="Mökkiprojekti - Etusivu">
    
    { !isAuthenticated ? (
        <div class="laatikko kirjautuminen">
            <h2>Sivu on suojattu</h2>
            <p>Syötä mökin yhteinen tunnus nähdäksesi sisällön.</p>
            
            <form method="POST">
                <input type="email" name="email" placeholder="Sähköposti (esim. mokki@meidanperhe.fi)" required style="margin-bottom: 12px; width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #ccc;" />
                
                <input type="password" name="password" placeholder="Salasana" required style="margin-bottom: 12px; width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #ccc;" />
                
                { errorMessage && <p class="virhe" style="color: red; margin-bottom: 12px;">{errorMessage}</p> }
                <button type="submit">Kirjaudu sisään</button>
            </form>
        </div>
    ) : (
        <a href="/works" class="laatikko laatikko-kuvalla" style="background-image: url('/tools.jpg');">
            <div class="kortti-sisalto keskitys">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-tools"></i> 
                    <h2>Työlista & Tarvikkeet</h2>
                </div>
            </div>
        </a>

        <a href="/guestbook" class="laatikko laatikko-kuvalla" style="background-image: url('/guestbook.jpg');">
            <div class="kortti-sisalto keskitys">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-book-open"></i> 
                    <h2>Vieraskirja</h2>
                </div>
            </div>
        </a>
    ) }

</MainLayout>