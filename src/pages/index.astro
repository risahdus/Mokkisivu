---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="HONKANIEMI - Etusivu">
    
    <div id="kirjautumis-laatikko" class="laatikko kirjautuminen">
        <h2>Sivu on suojattu</h2>
        <p>Syötä mökin yhteinen tunnus nähdäksesi sisällön.</p>
        
        <form id="kirjautumis-lomake">
            <input type="email" id="email" placeholder="Sähköposti (esim. honkaniemi@kilpi.fi)" required style="margin-bottom: 12px; width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #ccc;" />
            <input type="password" id="password" placeholder="Salasana" required style="margin-bottom: 12px; width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #ccc;" />
            
            <p id="virhe-viesti" style="color: red; margin-bottom: 12px; display: none;"></p>
            <button type="submit">Kirjaudu sisään</button>
        </form>
    </div>

    <div id="kortti-laatikko" style="display: none;">

        <!-- SÄÄKORTTI (UUSI) -->
        <div class="laatikko laatikko-kuvalla saa-laatikko-pohja" style="background-image: url('/weather.jpg');">
            <div class="saa-overlay">
                <div class="saa-otsikko">
                    <h3><i class="fa-solid fa-cloud-sun"></i> Sää Vaajasalossa</h3>
                    <span id="saa-aika">Päivitetään...</span>
                </div>
                <div class="saa-sisalto">
                    <div class="saa-paaluku">
                        <span id="saa-lampotila">--</span><span class="yksikko">°C</span>
                    </div>
                    <div class="saa-info">
                        <p id="saa-kuvaus">Ladataan säätilaa...</p>
                        <p><i class="fa-solid fa-wind"></i> Tuuli: <span id="saa-tuuli">--</span> m/s</p>
                    </div>
                </div>
            </div>
        </div>

        <a href="/works" class="laatikko laatikko-kuvalla" style="background-image: url('/tools.jpg');">
            <div class="kortti-sisalto keskitys">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-tools"></i> 
                    <h2>Työlista & Tarvikkeet</h2>
                </div>
            </div>
        </a>

        <a href="/guestbook" class="laatikko laatikko-kuvalla" style="background-image: url('/guestbook.jpg');">
            <div class="kortti-sisalto keskitys">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-book-open"></i> 
                    <h2>Mökkikirja & Vieraskirja</h2>
                </div>
            </div>
        </a>
        
    </div>

</MainLayout>

<script>
    import { createClient } from '@supabase/supabase-js';

    // Syötetään se sinun varmistamasi URL ja avain suoraan tähän selaimelle
    const URL = "https://ydahjbdtueiimulyecws.supabase.co";
    const KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlkYWhqYmR0dWVpaW11bHllY3dzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0Nzc0NjQsImV4cCI6MjA5ODA1MzQ2NH0.JsdRxEYuyln8VRrJiQ68n_jJPd0Yq2ABjBqB5zVs2Po";

    const supabase = createClient(URL, KEY);

    const lomake = document.getElementById('kirjautumis-lomake');
    const virheElementti = document.getElementById('virhe-viesti');
    const kirjautumisNakyma = document.getElementById('kirjautumis-laatikko');
    const korttiNakyma = document.getElementById('kortti-laatikko');

    // Tarkistetaan onko istunto jo valmiiksi auki
    const tarkistaIstunto = async () => {
        const { data } = await supabase.auth.getSession();
        if (data?.session) {
            kirjautumisNakyma.style.display = 'none';
            korttiNakyma.style.display = 'block';
        }
    };
    tarkistaIstunto();

    lomake.addEventListener('submit', async (e) => {
        e.preventDefault();
        virheElementti.style.display = 'none';

        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        // Suora haku selaimesta Supabaseen
        const { data, error } = await supabase.auth.signInWithPassword({
            email,
            password
        });

        if (error) {
            virheElementti.innerText = "Virhe: " + error.message;
            virheElementti.style.display = 'block';
        } else if (data.user) {
            kirjautumisNakyma.style.display = 'none';
            korttiNakyma.style.display = 'block';
        }
    });

    // --- SÄÄNHAKU VAAJASALO ---
    const haeSaa = async () => {
        try {
            // Vaajasalon Lauharannantien koordinaatit
            const lat = 62.903;
            const lon = 27.845;
            const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,weather_code,wind_speed_10m&wind_speed_unit=ms&timezone=Europe%2FHelsinki`;
            
            const res = await fetch(url);
            const data = await res.json();
            
            if (data && data.current) {
                const temp = Math.round(data.current.temperature_2m);
                const tuuli = Math.round(data.current.wind_speed_10m);
                const koodi = data.current.weather_code;
                
                document.getElementById('saa-lampotila').innerText = (temp > 0 ? '+' : '') + temp;
                document.getElementById('saa-tuuli').innerText = tuuli.toString();
                
                // Selkokieliset sääkuvaukset WMO-koodien mukaan
                let kuvaus = "Selkeää";
                if (koodi >= 1 && koodi <= 3) kuvaus = "Puolipilvistä";
                else if (koodi >= 45 && koodi <= 48) kuvaus = "Sumuista";
                else if (koodi >= 51 && koodi <= 67) kuvaus = "Vesisadetta";
                else if (koodi >= 71 && koodi <= 77) kuvaus = "Lumisadetta";
                else if (koodi >= 80 && koodi <= 82) kuvaus = "Kuurosadetta";
                else if (koodi >= 95) kuvaus = "Ukkosta";
                
                document.getElementById('saa-kuvaus').innerText = kuvaus;
                document.getElementById('saa-aika').innerText = "Nyt";
            }
        } catch (e) {
            document.getElementById('saa-kuvaus').innerText = "Säätilaa ei saatu ladattua";
        }
    };

    // Käynnistetään säänhaku jos ollaan jo sisällä tai kutsutaan sitä onnistuneen loginin jälkeen
    haeSaa();


</script>