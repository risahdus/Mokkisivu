---
// Tuodaan yhteinen sivupohja englanninkielisellä nimellä
import MainLayout from '../layouts/MainLayout.astro';

// BACKEND: Koodimuuttujat ja salasanan tarkistus palvelimella
let isAuthenticated = false;
let errorMessage = "";
const CORRECT_PASSWORD = "Mokki2026";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const enteredPassword = data.get("password");

    if (enteredPassword === CORRECT_PASSWORD) {
      isAuthenticated = true;
    } else {
      errorMessage = "Väärä salasana, yritä uudelleen!";
    }
  } catch (error) {
    console.error(error);
  }
}
---

<MainLayout title="Mökkiprojekti - Etusivu">
    
    { !isAuthenticated ? (
        <div class="laatikko kirjautuminen">
            <h2>Sivu on suojattu</h2>
            <p>Syötä mökin salasana nähdäksesi remonttilistan.</p>
            
            <form method="POST">
                <input type="password" name="password" placeholder="Salasana" required />
                { errorMessage && <p class="virhe">{errorMessage}</p> }
                <button type="submit">Kirjaudu sisään</button>
            </form>
        </div>
    ) : (
        <div class="laatikko laatikko-kuvalla" style="background-image: url('/tools.jpg');">
            <div class="kortti-sisalto">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-tools"></i> 
                    <h2>Työlista & Tarvikkeet</h2>
                </div>
                <ul>
                    <li>
                        <span>Terassin laajennus</span>
                        <span class="status kesken">Tarvikkeet ostamatta</span>
                    </li>
                    <li>
                        <span>Saunan lauteiden vahaus</span>
                        <span class="status tehty">Tehty & hankittu</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="laatikko laatikko-kuvalla" style="background-image: url('/guestbook.jpg');">
            <div class="kortti-sisalto">
                <div class="otsikko-rivi">
                    <i class="fa-solid fa-book-open"></i> 
                    <h2>Vieraskirja</h2>
                </div>
                <p>Tähän tulee myöhemmin lomake, johon voi kirjoittaa viestejä.</p>
            </div>
        </div>
    ) }

</MainLayout>