---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Avoimet & Kesken olevat työt">
    <div class="sivu-säiliö">
        <h2><i class="fa-solid fa-hourglass-half" style="color: #f59e0b;"></i> Avoimet & Kesken olevat työt</h2>
        <p class="sivun-kuvaus">Tältä sivulta löydät kaikki mökin odottavat remontit ja käynnissä olevat urakat.</p>

        <div id="lataus" class="keskitys">Ladataan projekteja...</div>
        <div id="projekti-lista" class="lista-virta"></div>

        <div style="margin-top: 35px;">
            <a href="/works" class="paluu-linkki"><i class="fa-solid fa-arrow-left"></i> Takaisin valikkoon</a>
        </div>
    </div>
</MainLayout>

<script>
    import { supabase } from '../../lib/supabase';

    const listaElementti = document.getElementById('projekti-lista');
    const latausElementti = document.getElementById('lataus');

    const haeAvoimetProjektit = async () => {
        if (!listaElementti) return;

        const { data: projektit, error } = await supabase
            .from('projektit')
            .select('*')
            .neq('status', 'valmis')
            .order('luotu_at', { ascending: false });

        if (latausElementti) latausElementti.style.display = 'none';

        if (error) {
            listaElementti.innerHTML = `<p style="color: red; text-align: center;">Virhe haettaessa tietoja: ${error.message}</p>`;
            return;
        }

        if (!projektit || projektit.length === 0) {
            listaElementti.innerHTML = '<p class="keskitys">Ei avoimia projekteja! Kaikki työt tehty tai listat tyhjänä. 🥂</p>';
            return;
        }

        listaElementti.innerHTML = '';

        projektit.forEach(projekti => {
            const kortti = document.createElement('a');
            kortti.href = `/projects/${projekti.id}`;
            kortti.className = 'remontti-kortti-laatikko'; // Uusi selkeä korttikehys
            
            const onKesken = projekti.status === 'kesken';
            const statusTeksti = onKesken ? 'Kesken' : 'Avoin';
            const statusLuokka = onKesken ? 'tagi-kesken' : 'tagi-avoin';

            // Tarvike-lohko
            let tarvikkeetHtml = '';
            if (projekti.tarvikkeet && projekti.tarvikkeet.trim() !== '') {
                tarvikkeetHtml = `
                    <div class="kortti-osio">
                        <strong class="vali-otsikko"><i class="fa-solid fa-basket-shopping"></i> Tarvikkeet & Materiaalit</strong>
                        <p class="osion-teksti tarvike-vari">${projekti.tarvikkeet}</p>
                    </div>
                `;
            }

            kortti.innerHTML = `
                <div class="kortti-ylatunniste">
                    <h3>${projekti.nimi}</h3>
                    <span class="status-tagi ${statusLuokka}">${statusTeksti}</span>
                </div>
                
                <div class="kortti-osio">
                    <strong class="vali-otsikko"><i class="fa-solid fa-file-lines"></i> Projektin kuvaus</strong>
                    <p class="osion-teksti">${projekti.kuvaus || 'Ei kuvausta.'}</p>
                </div>
                
                ${tarvikkeetHtml}
                
                <div class="kortti-alatunniste">
                    <div class="meta-pala">
                        <strong class="vali-otsikko-pieni"><i class="fa-solid fa-user"></i> Vastuuhenkilö</strong>
                        <span>${projekti.tekija || 'Ei tekijää'}</span>
                    </div>
                    <div class="meta-pala">
                        <strong class="vali-otsikko-pieni"><i class="fa-solid fa-euro-sign"></i> Kustannusarvio</strong>
                        <span class="hinta-korostus">${projekti.kustannus} €</span>
                    </div>
                </div>
            `;
            listaElementti.appendChild(kortti);
        });
    };

    haeAvoimetProjektit();
</script>

<style>
    .sivu-säiliö {
        max-width: 700px;
        margin: 0 auto;
        padding: 20px 15px;
    }
    h2 {
        font-size: 1.8rem;
        margin-bottom: 6px;
        color: #111827;
    }
    .sivun-kuvaus {
        color: #6b7280;
        margin: 0 0 24px 0;
    }
    
    .lista-virta {
        display: flex;
        flex-direction: column;
        gap: 24px; /* Selkeä väli korttien välille */
        margin-top: 20px;
    }
    
    /* VALMIS, RAJATTU KORTTI (Ei alleviivausta, harmaa tyylikäs pohja) */
    .remontti-kortti-laatikko {
        display: flex;
        flex-direction: column;
        text-decoration: none !important;
        color: #1f2937 !important;
        background: #f9fafb; /* Kevyt vaaleanharmaa tausta, jotta kortti erottuu */
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .remontti-kortti-laatikko:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        border-color: #cbd5e1;
    }
    
    /* Kortin yläreuna */
    .kortti-ylatunniste {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 12px;
        margin-bottom: 16px;
    }
    .kortti-ylatunniste h3 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
        color: #111827;
    }

    /* Status-pillerit */
    .status-tagi {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .tagi-avoin { background: #fef3c7; color: #b45309; border: 1px solid #fde68a; }
    .tagi-kesken { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }

    /* Väliotsikot ja osiot */
    .kortti-osio {
        margin-bottom: 16px;
    }
    .vali-otsikko {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        font-weight: 700;
        color: #4b5563;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 4px;
    }
    .vali-otsikko i {
        color: #9ca3af;
    }
    .osion-teksti {
        margin: 0;
        font-size: 1rem;
        color: #374151;
        line-height: 1.5;
        white-space: pre-line;
    }
    .tarvike-vari {
        color: #0369a1; /* Sinertävä väri tarvikkeille erottuvuuden vuoksi */
        font-weight: 500;
    }

    /* Kortin alareuna (Meta-tiedot rinnakkain) */
    .kortti-alatunniste {
        display: flex;
        gap: 40px;
        border-top: 1px solid #e5e7eb;
        padding-top: 14px;
        margin-top: 8px;
    }
    .meta-pala {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .vali-otsikko-pieni {
        font-size: 0.8rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
    }
    .hinta-korostus {
        font-weight: 700;
        color: #111827;
    }

    /* Paluulinkki */
    .paluu-linkki {
        display: inline-block;
        color: #374151;
        text-decoration: none;
        font-weight: 600;
        padding: 10px 20px;
        background: #f3f4f6;
        border-radius: 8px;
    }
    .paluu-linkki:hover { background: #e5e7eb; }
    .keskitys { text-align: center; padding: 40px; color: #6b7280; }
</style>