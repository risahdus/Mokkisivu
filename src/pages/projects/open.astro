---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Avoimet & Kesken olevat työt">
    <div class="sivu-säiliö">
        <h2><i class="fa-solid fa-hourglass-half" style="color: #f59e0b;"></i> Avoimet & Kesken olevat työt</h2>
        <p class="sivun-kuvaus">Tältä sivulta löydät kaikki mökin odottavat remontit ja käynnissä olevat urakat.</p>

        <!-- Lataus-indikaattori ja lista -->
        <div id="lataus" class="keskitys">Ladataan projekteja...</div>
        <div id="projekti-lista" class="lista-virta"></div>

        <div style="margin-top: 35px;">
            <a href="/works" class="paluu-linkki"><i class="fa-solid fa-arrow-left"></i> Takaisin valikkoon</a>
        </div>
    </div>
</MainLayout>

<script>
    import { supabase } from '../../lib/supabase';

    const listaElementti = document.getElementById('projekti-lista');
    const latausElementti = document.getElementById('lataus');

    const haeAvoimetProjektit = async () => {
        if (!listaElementti) return;

        const { data: projektit, error } = await supabase
            .from('projektit')
            .select('*')
            .neq('status', 'valmis')
            .order('luotu_at', { ascending: false });

        if (latausElementti) latausElementti.style.display = 'none';

        if (error) {
            listaElementti.innerHTML = `<p style="color: red; text-align: center;">Virhe haettaessa tietoja: ${error.message}</p>`;
            return;
        }

        if (!projektit || projektit.length === 0) {
            listaElementti.innerHTML = '<p class="keskitys">Ei avoimia projekteja! Kaikki työt tehty tai listat tyhjänä. 🥂</p>';
            return;
        }

        // Tyhjennetään lista varmuuden vuoksi
        listaElementti.innerHTML = '';

        projektit.forEach(projekti => {
            const kortti = document.createElement('a');
            kortti.href = `/projects/${projekti.id}`;
            kortti.className = 'remontti-kortti'; // Käytetään täysin uutta, puhdasta luokkaa
            
            const onKesken = projekti.status === 'kesken';
            const statusTeksti = onKesken ? 'Kesken' : 'Avoin';
            const statusLuokka = onKesken ? 'tagi-kesken' : 'tagi-avoin';

            // Rakennetaan tarvike-osio vain jos tarvikkeita on syötetty
            let tarvikkeetHtml = '';
            if (projekti.tarvikkeet && projekti.tarvikkeet.trim() !== '') {
                tarvikkeetHtml = `
                    <div class="tarvike-laatikko">
                        <strong class="tarvike-otsikko"><i class="fa-solid fa-basket-shopping"></i> Tarvikkeet:</strong>
                        <p class="tarvike-sisalto">${projekti.tarvikkeet}</p>
                    </div>
                `;
            }

            kortti.innerHTML = `
                <div class="kortti-runko">
                    <div class="otsikko-rivi">
                        <h3>${projekti.nimi}</h3>
                        <span class="status-tagi ${statusLuokka}">${statusTeksti}</span>
                    </div>
                    
                    <p class="kuvaus-teksti">${projekti.kuvaus || 'Ei kuvausta.'}</p>
                    
                    ${tarvikkeetHtml}
                    
                    <div class="metatiedot-rivi">
                        <span class="meta-tieto"><i class="fa-solid fa-user"></i> ${projekti.tekija || 'Ei tekijää'}</span>
                        <span class="meta-tieto hinta-tagi"><i class="fa-solid fa-euro-sign"></i> ${projekti.kustannus} €</span>
                    </div>
                </div>
                <div class="kortti-nuoli">
                    <i class="fa-solid fa-chevron-right"></i>
                </div>
            `;
            listaElementti.appendChild(kortti);
        });
    };

    haeAvoimetProjektit();
</script>

<style>
    /* Sivun perusrakenne */
    .sivu-säiliö {
        max-width: 750px;
        margin: 0 auto;
        padding: 20px 15px;
    }
    h2 {
        font-size: 1.8rem;
        margin-bottom: 6px;
        color: #111827;
    }
    .sivun-kuvaus {
        color: #6b7280;
        margin: 0 0 24px 0;
        font-size: 1rem;
    }
    
    /* Lista-astia */
    .lista-virta {
        display: flex;
        flex-direction: column;
        gap: 20px; /* Korttien välinen rako */
        margin-top: 20px;
    }
    
    /* UUSI PUHDAS KORTTI (Valkoinen pohja, tumma teksti, ei alleviivauksia) */
    .remontti-kortti {
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-decoration: none !important; /* Estää alleviivaukset */
        color: #1f2937 !important; /* Tumma tekstiväri */
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 20px; /* Sisäiset marginaalit kuntoon */
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .remontti-kortti:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0,0,0,0.1);
        border-color: #cbd5e1;
    }
    
    .kortti-runko {
        flex: 1;
    }

    /* Otsikko + Status pilleri */
    .otsikko-rivi {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 12px;
    }
    .otsikko-rivi h3 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 700;
        color: #111827;
        line-height: 1.4;
    }

    /* Status-pillerien tyylit */
    .status-tagi {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }
    .tagi-avoin {
        background: #fef3c7;
        color: #b45309;
        border: 1px solid #fde68a;
    }
    .tagi-kesken {
        background: #e0f2fe;
        color: #0369a1;
        border: 1px solid #bae6fd;
    }

    /* Kuvausteksti */
    .kuvaus-teksti {
        font-size: 0.95rem;
        color: #4b5563;
        margin: 0 0 16px 0;
        line-height: 1.5;
    }

    /* Tarvikelaatikko (Harmaa, siisti sisennys) */
    .tarvike-laatikko {
        background: #f8fafc;
        border-left: 4px solid #64748b;
        padding: 12px 16px;
        margin-bottom: 16px;
        border-radius: 0 6px 6px 0;
    }
    .tarvike-otsikko {
        font-size: 0.85rem;
        font-weight: 700;
        color: #475569;
        display: block;
        margin-bottom: 4px;
        text-transform: uppercase;
    }
    .tarvike-sisalto {
        margin: 0;
        color: #334155;
        font-size: 0.9rem;
        line-height: 1.4;
        white-space: pre-line;
    }

    /* Alarivi (Metatiedot: Tekijä ja Hinta) */
    .metatiedot-rivi {
        display: flex;
        gap: 24px;
        padding-top: 12px;
        border-top: 1px solid #f3f4f6;
    }
    .meta-tieto {
        font-size: 0.85rem;
        color: #6b7280;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .meta-tieto i {
        color: #9ca3af;
    }
    .hinta-tagi {
        font-weight: 600;
        color: #1f2937;
    }

    /* Pieni nuoli kortin oikeassa reunassa */
    .kortti-nuoli {
        color: #9ca3af;
        font-size: 1.1rem;
        padding-left: 20px;
        transition: transform 0.2s;
    }
    .remontti-kortti:hover .kortti-nuoli {
        transform: translateX(4px);
        color: #4b5563;
    }

    /* Paluupainike sivun alareunassa */
    .paluu-linkki {
        display: inline-block;
        color: #374151;
        text-decoration: none;
        font-weight: 600;
        padding: 10px 20px;
        background: #f3f4f6;
        border-radius: 8px;
        transition: background 0.2s;
    }
    .paluu-linkki:hover { background: #e5e7eb; }
    .keskitys { text-align: center; padding: 40px; color: #6b7280; }
</style>