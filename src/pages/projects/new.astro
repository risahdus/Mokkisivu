---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Lisää uusi projekti">
    <div class="sivu-säiliö">
        <h2><i class="fa-solid fa-circle-plus" style="color: #3b82f6;"></i> Lisää uusi projekti</h2>
        <p>Kirjaa ylös uusi remontti, huoltotyö tai tarvikehanke.</p>

        <div id="admin-lukitus" class="laatikko tumma-lomake" style="max-width: 400px; margin: 24px auto 0 auto; text-align: center;">
            <i class="fa-solid fa-lock" style="font-size: 2.5rem; color: #ef4444; margin-bottom: 16px;"></i>
            <h3>Vaatii ylläpitäjän salasanan</h3>
            <p style="color: #ccc; font-size: 0.9rem;">Tämä sivu on suojattu. Syötä admin-salasana jatkaaksesi.</p>
            
            <div class="lomake-ryhma" style="margin-top: 16px; text-align: left;">
                <label for="admin-password">Admin-salasana</label>
                <input type="password" id="admin-password" placeholder="••••••••" />
            </div>
            <p id="admin-virhe" style="color: #fca5a5; font-size: 0.9rem; display: none; margin-bottom: 10px; font-weight: 600;"></p>
            <button id="admin-nappi" style="margin-top: 10px; background: #ef4444;">Avaa lukitus</button>
        </div>

        <form id="projekti-lomake" class="laatikko tumma-lomake" style="display: none;">
            <div class="lomake-ryhma">
                <label for="nimi">Projektin nimi *</label>
                <input type="text" id="nimi" placeholder="Esim. Terassin huoltomaalaus" required />
            </div>

            <div class="lomake-ryhma">
                <label for="kuvaus">Kuvaus / Ohjeet</label>
                <textarea id="kuvaus" rows="4" placeholder="Mitä tehdään? Ohjeet, värikoodit jne..."></textarea>
            </div>

            <div class="lomake-rivi">
                <div class="lomake-ryhma">
                    <label for="tekija">Vastuuhenkilö / Tekijä</label>
                    <input type="text" id="tekija" placeholder="Esim. Jussi" />
                </div>
                <div class="lomake-ryhma">
                    <label for="kustannus">Arvioitu kustannus (€)</label>
                    <input type="number" id="kustannus" min="0" value="0" />
                </div>
            </div>
            <div class="lomake-ryhma">
                <label for="status">Projektin tila / Status</label>
                <select id="status">
                    <option value="avoin">Avoin (Odottaa aloittamista)</option>
                    <option value="kesken">Kesken (Aloitettu/Työn alla)</option>
                    <option value="valmis">Valmis (Urakka ohi ja arkistoitu)</option>
                </select>
            </div>            

            <div class="lomake-ryhma">
                <label for="tarvikkeet">Tarvittavat materiaalit & Työkalut</label>
                <textarea id="tarvikkeet" rows="3" placeholder="Esim. Terassiöljy 5L, pensselit, hiomapaperi..."></textarea>
            </div>

            <p id="tila-viesti" class="viesti" style="display: none;"></p>

            <div class="nappi-rivi">
                <button type="submit" id="tallenna-nappi">Tallenna projekti kantaan</button>
            </div>
        </form>

        <div style="margin-top: 30px;">
            <a href="/works" class="paluu-linkki"><i class="fa-solid fa-arrow-left"></i> Takaisin valikkoon</a>
        </div>
    </div>
</MainLayout>

<script>
    import { supabase } from '../../lib/supabase';

    // Määritetään se admin-salasana tähän lennosta
    const ADMIN_PASSWORD = "MokkiAdmin2026";

    const lukitusNakyma = document.getElementById('admin-lukitus');
    const lomakeNakyma = document.getElementById('projekti-lomake') as HTMLFormElement;
    const adminPassInput = document.getElementById('admin-password') as HTMLInputElement;
    const adminVirhe = document.getElementById('admin-virhe');
    const adminNappi = document.getElementById('admin-nappi');

    // Tarkistetaan onko lukitus avattu jo aiemmin tässä istunnossa
    if (sessionStorage.getItem('isMokkiAdmin') === 'true') {
        lukitusNakyma.style.display = 'none';
        lomakeNakyma.style.display = 'block';
    }

    // Lukituksen avaustoiminto
    const tarkistaAdminSalasana = () => {
        if (adminPassInput.value === ADMIN_PASSWORD) {
            // Tallenna tieto istuntoon, jotta sivu ei kysy salasanaa uudestaan virkistyksessä
            sessionStorage.setItem('isMokkiAdmin', 'true');
            
            // Vaihdetaan näkymät lennosta
            lukitusNakyma.style.display = 'none';
            lomakeNakyma.style.display = 'block';
        } else {
            adminVirhe.innerText = "Väärä salasana! Yritä uudelleen.";
            adminVirhe.style.display = 'block';
            adminPassInput.value = '';
        }
    };

    adminNappi.addEventListener('click', tarkistaAdminSalasana);
    adminPassInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') tarkistaAdminSalasana();
    });


    // --- PROJEKTIN TALLENNUSLOGIIKKA (pysyy samana) ---
    const viestiElementti = document.getElementById('tila-viesti');
    const nappi = document.getElementById('tallenna-nappi') as HTMLButtonElement;

    lomakeNakyma.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        nappi.disabled = true;
        nappi.innerText = "Tallennetaan...";
        viestiElementti.style.display = 'none';
        viestiElementti.className = 'viesti';

        const nimi = (document.getElementById('nimi') as HTMLInputElement).value;
        const kuvaus = (document.getElementById('kuvaus') as HTMLTextAreaElement).value;
        const tekija = (document.getElementById('tekija') as HTMLInputElement).value;
        const kustannus = parseFloat((document.getElementById('kustannus') as HTMLInputElement).value) || 0;
        const tarvikkeet = (document.getElementById('tarvikkeet') as HTMLTextAreaElement).value;
        const status = (document.getElementById('status') as HTMLSelectElement).value;

        const { error } = await supabase
            .from('projektit')
            .insert([
                { 
                    nimi, 
                    kuvaus, 
                    tekija, 
                    kustannus, 
                    tarvikkeet, 
                    status // Käytetään valittua statusta 'avoin' sijaan
                }
            ]);

        if (error) {
            viestiElementti.innerText = "Virhe tallennuksessa: " + error.message;
            viestiElementti.classList.add('virhe');
            viestiElementti.style.display = 'block';
            nappi.disabled = false;
            nappi.innerText = "Tallenna projekti kantaan";
        } else {
            viestiElementti.innerText = "✓ Projekti tallennettu onnistuneesti avaamattomiin töihin!";
            viestiElementti.classList.add('onnistuminen');
            viestiElementti.style.display = 'block';
            lomakeNakyma.reset();
            
            setTimeout(() => {
                nappi.disabled = false;
                nappi.innerText = "Tallenna projekti kantaan";
            }, 2000);
        }
    });
</script>

<style>
    .sivu-säiliö {
        max-width: 650px;
        margin: 0 auto;
        padding: 20px 0;
    }
    h2 { font-size: 2rem; margin-bottom: 8px; }
    h3 { margin: 0 0 8px 0; color: #fff; }
    
    .tumma-lomake {
        background: #1a1a1a;
        color: #ffffff;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        margin-top: 24px;
    }
    .lomake-ryhma { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
    .lomake-rivi { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    label { font-size: 0.9rem; font-weight: 600; color: #ccc; }
    input, textarea { padding: 12px; border-radius: 6px; border: 1px solid #444; background: #2a2a2a; color: #ffffff; font-size: 1rem; }
    input, textarea, select { padding: 12px; border-radius: 6px; border: 1px solid #444; background: #2a2a2a; color: #ffffff; font-size: 1rem; }
    input:focus, textarea:focus { outline: none; border-color: #3b82f6; }

    button {
        width: 100%;
        padding: 14px;
        background: #3b82f6;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
    }
    button:hover { filter: brightness(1.1); }
    button:disabled { background: #555 !important; cursor: not-allowed; }

    .viesti { padding: 12px; border-radius: 6px; margin-bottom: 20px; font-weight: 600; text-align: center; }
    .virhe { background: #7f1d1d; color: #fca5a5; border: 1px solid #991b1b; }
    .onnistuminen { background: #064e3b; color: #6ee7b7; border: 1px solid #065f46; }
    .paluu-linkki { display: inline-block; color: #333; text-decoration: none; font-weight: 600; padding: 8px 16px; background: #f0f0f0; border-radius: 6px; }
    .paluu-linkki:hover { background: #e0e0e0; }

    @media (max-width: 480px) { .lomake-rivi { grid-template-columns: 1fr; gap: 0; } }
</style>