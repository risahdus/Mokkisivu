---
// Otetaan vastaan sivun otsikko muuttujana (prop)
const { otsikko = "Mökkisivu" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{otsikko}</title>
    <style is:global>
        /* Tänne siirrettiin kaikki yleiset tyylit */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            line-height: 1.6;
            background-color: #f2f0eb;
            color: #2c3e2b;
            padding: 20px;
        }
        .container { max-width: 600px; margin: 40px auto; }
        h1 { text-align: center; margin-bottom: 30px; color: #1b331e; }
        .laatikko {
            background: #ffffff;
            padding: 25px;
            margin-bottom: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        }
        h2 { font-size: 1.3rem; margin-bottom: 15px; color: #1b331e; border-bottom: 2px solid #e5e2da; padding-bottom: 8px; }
        ul { list-style: none; }
        li { padding: 10px 0; border-bottom: 1px solid #f5f4f0; display: flex; align-items: center; justify-content: space-between; }
        li:last-child { border-bottom: none; }
        .status { font-size: 0.85rem; padding: 4px 8px; border-radius: 6px; font-weight: 600; }
        .tehty { background-color: #e2f0d9; color: #385723; }
        .kesken { background-color: #fff2cc; color: #7f6000; }
        p { color: #555; font-size: 0.95rem; }

        /* Kirjautumisen tyylit */
        .kirjautuminen { text-align: center; }
        input[type="password"] {
            width: 100%;
            padding: 12px;
            margin: 15px 0;
            border: 2px solid #e5e2da;
            border-radius: 8px;
            font-size: 1rem;
        }
        button {
            background-color: #1b331e;
            color: white;
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            cursor: pointer;
            width: 100%;
        }
        button:hover { background-color: #2c3e2b; }
        .virhe { color: #b33a3a; margin-bottom: 15px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h1>HONKANIEMI</h1>
        
        <slot /> 
        
    </div>
</body>
</html>